# Handoff Server Configuration
# Copy to .env and customize for your environment.

# --- Core (required) ---
DATABASE_URL=postgresql+asyncpg://handoff:handoff@localhost:5432/handoff
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY_HOURS=24
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- Cloud Extension (optional — only needed with handoff-cloud) ---

# PII encryption key (AES-256-GCM) — REQUIRED if running cloud extension
# PII_ENCRYPTION_KEY=your-32-char-encryption-key-here

# Stripe billing
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_TEAM=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# OAuth providers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# OAUTH_REDIRECT_BASE=http://localhost:3000
