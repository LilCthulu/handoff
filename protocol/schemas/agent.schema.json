{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://handoff.dev/schemas/agent.schema.json",
  "title": "Agent Identity & Capability Declaration",
  "description": "Defines an agent's identity, public key, capabilities, and authority limits.",
  "type": "object",
  "required": ["name", "owner_id", "public_key", "capabilities"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique agent identifier (assigned by server)"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "description": "Human-readable agent name"
    },
    "description": {
      "type": "string",
      "description": "What this agent does"
    },
    "owner_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "description": "Human or organization that owns this agent"
    },
    "public_key": {
      "type": "string",
      "description": "Ed25519 public key in base64 encoding"
    },
    "capabilities": {
      "type": "array",
      "items": { "$ref": "#/$defs/capability" },
      "description": "List of capability declarations"
    },
    "trust_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "default": 0.5,
      "description": "Computed trust score from interaction history"
    },
    "max_authority": {
      "type": "object",
      "description": "Spending limits, action scopes, and other authority constraints",
      "properties": {
        "max_spend": { "type": "number", "minimum": 0 },
        "currency": { "type": "string" },
        "allowed_domains": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requires_human_approval": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "status": {
      "type": "string",
      "enum": ["active", "suspended", "revoked"],
      "default": "active"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "last_seen_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "capability": {
      "type": "object",
      "required": ["domain", "actions"],
      "properties": {
        "domain": {
          "type": "string",
          "description": "Capability domain (e.g. travel, communication, finance)"
        },
        "actions": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Actions this agent can perform in the domain"
        },
        "constraints": {
          "type": "object",
          "additionalProperties": true,
          "description": "Domain-specific constraints on these capabilities"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
